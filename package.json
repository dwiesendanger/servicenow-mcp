{
  "name": "@dwiesendanger/servicenow-mcp",
  "version": "1.1.0",
  "description": "MCP server for ServiceNow incident management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "servicenow-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "servicenow",
    "incident-management",
    "itsm",
    "ai-tools",
    "cline"
  ],
  "author": "Dominik Wiesendanger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dwiesendanger/servicenow-mcp.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.3"
  }
}
