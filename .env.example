# ServiceNow MCP Server – Environment Configuration
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will NOT be committed.

# ─── Required ────────────────────────────────────────────────────────────────
# ServiceNow instance URL (no trailing slash)
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com

# ServiceNow credentials – KEEP THESE IN .env ONLY, never in MCP config!
SERVICENOW_USERNAME=your-username
SERVICENOW_PASSWORD=your-password

# ─── Optional ────────────────────────────────────────────────────────────────
# Set to "false" to disable all write operations (create, update, resolve, add comment)
# SERVICENOW_ALLOW_WRITE=false

# Set to "true" to disable PII redaction (not recommended in production)
# SERVICENOW_DISABLE_REDACTION=true
